{
  "manifest_version": 3,
  "name": "Canvas AI 分析",
  "version": "1.0.0",
  "description": "抓取网页 canvas 并进行 AI 实时分析",
  "permissions": [
    "activeTab",
    "scripting",
    "offscreen",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Canvas AI 分析",
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' chrome-extension: data: blob:"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "models/*",
        "models/**/*",
        "worker.js",
        "js/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
