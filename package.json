  "devDependencies": {
    "@types/chrome": "0.0.268",
    "copy-webpack-plugin": "5.1.2",
    "css-loader": "5.2.7",
    "mini-css-extract-plugin": "1.6.2",
    "sass": "1.32.13",
    "sass-loader": "10.1.1",
    "ts-loader": "8.4.0",
    "typescript": "4.5.5",
    "webpack": "4.46.0",
    "webpack-cli": "3.3.12"
  }
