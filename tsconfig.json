{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["DOM", "ES2018", "WebWorker"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/ai/*"]
    },
    "types": ["chrome"]
  },
  "include": ["src/**/*", "src/types/globals.d.ts"],
  "exclude": ["node_modules", "dist"]
}
